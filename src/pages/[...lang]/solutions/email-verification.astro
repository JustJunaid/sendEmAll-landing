---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import ServicePage from "@/layouts/components/sections/ServicePage.astro";

export function getStaticPaths() {
  return generatePaths();
}

const meta = {
  title: "Email Verification | Never Send to a Dead Email | SendEmAll",
  description: "Multi-layer verification catches invalid, catch-all, and disposable addresses before you send. Protect your sender reputation.",
};

const features = [
  { title: "Email syntax validation", description: "Catches typos, formatting errors, and malformed addresses before they cost you credits." },
  { title: "MX record check", description: "Verifies the recipient's domain has valid mail servers configured and accepting mail." },
  { title: "SMTP verification", description: "Connects to the mail server to confirm the specific mailbox exists and is active." },
  { title: "Catch-all detection", description: "Identifies domains that accept all addresses — high bounce risk flagged before sending." },
  { title: "Disposable email filtering", description: "Detects temporary and throwaway email addresses that will never convert." },
  { title: "Bounce prediction", description: "ML-based scoring predicts bounce probability so you can set your own risk threshold." },
];

const steps = [
  { num: "01", title: "Upload or pipeline leads", description: "Import a CSV, connect your CRM, or let verified leads flow in from our discovery engine." },
  { num: "02", title: "We verify every address", description: "Six-layer verification runs on every email. Invalid, risky, and disposable addresses are flagged." },
  { num: "03", title: "Only valid emails proceed", description: "Clean, verified addresses move to your campaign. Bad emails never waste your credits." },
];

const providers = [
  { name: "MailTester.ninja", description: "Primary email verification" },
  { name: "MX lookup", description: "Domain mail server validation" },
  { name: "SMTP verifier", description: "Mailbox existence check" },
  { name: "Disposable DB", description: "Throwaway email detection" },
];

const pricing = [
  { action: "Email verification", credits: "1 credit per email" },
];
---

<Base {...meta}>
  <ServicePage
    title={meta.title}
    description={meta.description}
    label="Email Verification"
    headline="Never send to a dead email again"
    subtitle="Multi-layer verification catches invalid, catch-all, and disposable addresses before you send."
    features={features}
    steps={steps}
    providers={providers}
    pricing={pricing}
    pricingNote="Included in all plans."
  />
</Base>
