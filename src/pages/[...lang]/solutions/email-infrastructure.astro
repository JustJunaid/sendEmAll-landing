---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import ServicePage from "@/layouts/components/sections/ServicePage.astro";

export function getStaticPaths() {
  return generatePaths();
}

const meta = {
  title: "Email Infrastructure | Managed Domains & Mailboxes | SendEmAll",
  description: "We buy domains, set up Google Workspace, configure SPF/DKIM/DMARC, and run Smart Ramp-Up. Zero DNS headaches. You just send.",
};

const features = [
  { title: "Managed domains", description: "We purchase and configure sending domains for you. No registrar juggling." },
  { title: "Google Workspace mailboxes", description: "Professional mailboxes on Google Workspace, fully managed and ready to send." },
  { title: "SPF/DKIM/DMARC auto-config", description: "Authentication records configured automatically. Maximum deliverability from day one." },
  { title: "Smart Ramp-Up", description: "Gradual sending volume increase builds sender reputation safely. No shortcuts, no risk." },
  { title: "30-40 emails/day per mailbox", description: "Optimal daily volume per mailbox to maintain high deliverability rates." },
  { title: "Deliverability monitoring", description: "Real-time tracking of inbox placement, bounces, and reputation scores." },
];

const steps = [
  { num: "01", title: "Choose your plan", description: "Pick the plan that matches your outreach volume. Pro starts at 15 mailboxes." },
  { num: "02", title: "We set up everything", description: "Domains purchased, DNS configured, mailboxes created, Smart Ramp-Up started. You do nothing." },
  { num: "03", title: "Start sending in 14-21 days", description: "Once ramp-up completes, your mailboxes are warmed and ready for full-volume campaigns." },
];

const providers = [
  { name: "Google Workspace", description: "Enterprise email platform" },
  { name: "Cloudflare DNS", description: "DNS management & security" },
  { name: "Deliverability monitor", description: "Inbox placement tracking" },
  { name: "Rotation engine", description: "Mailbox rotation & load balancing" },
];

const pricing = [
  { action: "Domain setup", credits: "Included" },
  { action: "Mailbox management", credits: "Included" },
  { action: "Smart Ramp-Up", credits: "Included" },
];
---

<Base {...meta}>
  <ServicePage
    title={meta.title}
    description={meta.description}
    label="Email Infrastructure"
    headline="Managed domains and mailboxes. Zero DNS headaches."
    subtitle="We buy domains, set up Google Workspace, configure SPF/DKIM/DMARC, and run Smart Ramp-Up. You send."
    features={features}
    steps={steps}
    providers={providers}
    pricing={pricing}
    pricingNote="Infrastructure is included in Pro, Business, and Scale plans."
  />
</Base>
