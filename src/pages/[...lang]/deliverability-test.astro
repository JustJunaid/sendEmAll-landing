---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";

export function getStaticPaths() {
  return generatePaths();
}

const meta = {
  title: "Free Email Deliverability Test | SendEmAll",
  description:
    "Test where your emails land — inbox, spam, or promotions — in minutes. Get your content score, sender reputation tips, and placement breakdown across 12+ email providers.",
  disableTagline: true,
};

const SEED_INBOXES_FALLBACK = [
  { email: "seed.test.gmail.1@gmail.com", provider: "Gmail" },
  { email: "seed.test.gmail.2@gmail.com", provider: "Gmail" },
  { email: "seed.test.gmail.3@gmail.com", provider: "Gmail" },
  { email: "seed.test.outlook.1@outlook.com", provider: "Outlook" },
  { email: "seed.test.outlook.2@outlook.com", provider: "Outlook" },
  { email: "seed.test.yahoo.1@yahoo.com", provider: "Yahoo" },
  { email: "seed.test.yahoo.2@yahoo.com", provider: "Yahoo" },
  { email: "seed.test.icloud.1@icloud.com", provider: "iCloud" },
  { email: "seed.test.proton.1@protonmail.com", provider: "ProtonMail" },
  { email: "seed.test.zoho.1@zohomail.com", provider: "Zoho" },
  { email: "seed.test.aol.1@aol.com", provider: "AOL" },
  { email: "seed.test.hotmail.1@hotmail.com", provider: "Hotmail" },
];
---

<Base {...meta} sectionSpacing="md">
  <!-- Hero -->
  <section class="relative overflow-hidden pt-24 pb-4">
    <div
      class="pointer-events-none absolute inset-0 -z-10"
      style="background: radial-gradient(ellipse 70% 40% at 50% 0%, rgba(210,179,243,0.12) 0%, transparent 70%);"
    >
    </div>
    <div class="container mx-auto max-w-4xl px-4 text-center">
      <div
        class="mb-4 inline-flex items-center gap-2 rounded-full border border-[#2A2433] bg-[#1A191C] px-4 py-1.5 text-sm text-[#D2B3F3]"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#D2B3F3] opacity-75"
          ></span>
          <span
            class="relative inline-flex h-2 w-2 rounded-full bg-[#D2B3F3]"
          ></span>
        </span>
        Free Deliverability Audit
      </div>
      <h1
        class="mb-4 text-4xl font-bold text-white md:text-5xl lg:text-6xl"
        style="font-family: 'Sora', sans-serif; line-height: 1.1;"
      >
        See exactly where<br />
        <span style="color: #D2B3F3;">your emails land</span>
      </h1>
      <p class="mx-auto mb-10 max-w-2xl text-lg text-[#C8C1C1]">
        Send a test email to our seed inboxes across Gmail, Outlook, Yahoo, and
        more. Get your inbox placement rate, spam score, and sender reputation
        — no account required.
      </p>

      <!-- Step indicator -->
      <div id="step-indicator" class="mx-auto mb-12 flex max-w-xs items-center justify-center gap-0">
        <div class="step-item flex flex-col items-center" data-step="1">
          <div
            class="step-circle flex h-9 w-9 items-center justify-center rounded-full border-2 border-[#D2B3F3] bg-[#D2B3F3] text-sm font-bold text-black transition-all duration-300"
          >
            1
          </div>
          <span class="mt-1.5 text-xs font-medium text-[#D2B3F3]">Send</span>
        </div>
        <div class="mb-5 h-px w-16 bg-[#2A2433] transition-all duration-500" id="connector-1"></div>
        <div class="step-item flex flex-col items-center" data-step="2">
          <div
            class="step-circle flex h-9 w-9 items-center justify-center rounded-full border-2 border-[#2A2433] bg-[#1A191C] text-sm font-bold text-[#C8C1C1] transition-all duration-300"
          >
            2
          </div>
          <span class="mt-1.5 text-xs font-medium text-[#C8C1C1] transition-all duration-300"
            >Results</span
          >
        </div>
      </div>
    </div>
  </section>

  <!-- Main wizard container -->
  <section class="pb-24">
    <div class="container mx-auto max-w-3xl px-4">

      <!-- ==================== STEP 1: SEND ==================== -->
      <div id="step-1" class="step-panel">

        <!-- Tracking code block -->
        <div class="mb-5 rounded-2xl border border-[#D2B3F3]/30 bg-[#1A191C] p-6 md:p-8">
          <div class="mb-4 flex items-center gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-[#D2B3F3]/10">
              <svg class="h-4.5 w-4.5 text-[#D2B3F3]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-white">Your tracking code</h3>
              <p class="text-xs text-[#6b6875]">Include this in your email subject or body</p>
            </div>
          </div>
          <div class="flex items-center gap-3 rounded-lg border border-[#2A2433] bg-[#0e0c0c] p-4">
            <code id="tracking-code" class="flex-1 font-mono text-base font-bold text-[#D2B3F3] tracking-wide select-all"></code>
            <button
              id="copy-code-btn"
              class="flex items-center gap-1.5 rounded-md border border-[#2A2433] bg-[#1A191C] px-3 py-1.5 text-xs text-[#C8C1C1] transition-all hover:border-[#D2B3F3]/50 hover:text-[#D2B3F3]"
            >
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2m-6 12h8a2 2 0 0 1 2-2v-8a2 2 0 0 1-2-2h-8a2 2 0 0 1-2 2v8a2 2 0 0 1 2 2Z"/>
              </svg>
              Copy
            </button>
          </div>
          <div class="mt-3 rounded-lg bg-[#D2B3F3]/5 px-4 py-3 text-xs text-[#C8C1C1]">
            <strong class="text-[#D2B3F3]">How to use:</strong> Add this code anywhere in your email subject line or body — e.g. <em>"[SEA-TEST-XXXXXX]"</em>. This lets us identify your email in the seed inboxes.
          </div>
        </div>

        <!-- Seed inboxes -->
        <div class="mb-5 rounded-2xl border border-[#2A2433] bg-[#1A191C] p-6 md:p-8">
          <div class="mb-5 flex items-center justify-between">
            <div>
              <h3 class="font-semibold text-white">Send to these addresses</h3>
              <p class="mt-0.5 text-xs text-[#6b6875]">Real inboxes across 12+ email providers</p>
            </div>
            <button
              id="copy-all-btn"
              class="flex items-center gap-1.5 rounded-lg border border-[#2A2433] bg-[#0e0c0c] px-3 py-2 text-xs font-medium text-[#C8C1C1] transition-all hover:border-[#D2B3F3]/50 hover:text-[#D2B3F3]"
            >
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2m-6 12h8a2 2 0 0 1 2-2v-8a2 2 0 0 1-2-2h-8a2 2 0 0 1-2 2v8a2 2 0 0 1 2 2Z"/>
              </svg>
              Copy all
            </button>
          </div>

          <!-- Loading state -->
          <div id="inboxes-loading" class="space-y-2.5">
            {Array.from({ length: 8 }).map(() => (
              <div class="flex animate-pulse items-center gap-3 rounded-lg border border-[#2A2433] bg-[#0e0c0c] px-4 py-3">
                <div class="h-3 w-3 rounded-full bg-[#2A2433]"></div>
                <div class="h-3 flex-1 rounded bg-[#2A2433]"></div>
                <div class="h-5 w-16 rounded-md bg-[#2A2433]"></div>
              </div>
            ))}
          </div>

          <!-- Inbox list (populated by JS) -->
          <div id="inbox-list" class="hidden space-y-2.5"></div>
        </div>

        <!-- Instructions -->
        <div class="mb-5 rounded-2xl border border-[#2A2433] bg-[#1A191C] p-6 md:p-8">
          <h3 class="mb-4 font-semibold text-white">How to send the test</h3>
          <ol class="space-y-4">
            <li class="flex gap-4">
              <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#D2B3F3]/10 text-xs font-bold text-[#D2B3F3]">1</div>
              <div>
                <p class="text-sm font-medium text-white">Open your email client</p>
                <p class="mt-0.5 text-xs text-[#6b6875]">Gmail, Outlook, Apple Mail, or any other client you use.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#D2B3F3]/10 text-xs font-bold text-[#D2B3F3]">2</div>
              <div>
                <p class="text-sm font-medium text-white">Compose your email</p>
                <p class="mt-0.5 text-xs text-[#6b6875]">Use the subject and body you entered above. Include the tracking code somewhere visible.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#D2B3F3]/10 text-xs font-bold text-[#D2B3F3]">3</div>
              <div>
                <p class="text-sm font-medium text-white">Paste all seed addresses in the To field</p>
                <p class="mt-0.5 text-xs text-[#6b6875]">Copy all addresses above and paste them as recipients. Most email clients accept comma-separated addresses.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#D2B3F3]/10 text-xs font-bold text-[#D2B3F3]">4</div>
              <div>
                <p class="text-sm font-medium text-white">Hit send, then come back here</p>
                <p class="mt-0.5 text-xs text-[#6b6875]">Click the button below and we'll check each inbox for your email and report where it landed.</p>
              </div>
            </li>
          </ol>
        </div>

        <button
          id="btn-sent"
          class="group flex w-full items-center justify-center gap-2 rounded-lg bg-[#D2B3F3] px-6 py-3.5 text-sm font-semibold text-black transition-all duration-200 hover:bg-[#B896E8]"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5"/>
          </svg>
          I've sent the emails — show my results
        </button>
      </div>

      <!-- ==================== STEP 2: ANALYZING ==================== -->
      <div id="step-2" class="step-panel hidden">
        <div class="rounded-2xl border border-[#2A2433] bg-[#1A191C] p-8 text-center md:p-12">
          <!-- Animated rings -->
          <div class="relative mx-auto mb-8 h-24 w-24">
            <div class="absolute inset-0 animate-spin rounded-full border-2 border-transparent border-t-[#D2B3F3]" style="animation-duration: 1.2s;"></div>
            <div class="absolute inset-2 animate-spin rounded-full border-2 border-transparent border-t-[#B896E8]" style="animation-duration: 1.8s; animation-direction: reverse;"></div>
            <div class="absolute inset-4 animate-spin rounded-full border-2 border-transparent border-t-[#D2B3F3]/50" style="animation-duration: 2.4s;"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <svg class="h-8 w-8 text-[#D2B3F3]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
              </svg>
            </div>
          </div>

          <h2 class="mb-2 text-2xl font-bold text-white">Checking your inboxes...</h2>
          <p class="mx-auto mb-8 max-w-sm text-sm text-[#C8C1C1]">
            We're scanning 12+ email providers for your message. This takes about 60 seconds.
          </p>

          <!-- Progress steps -->
          <div id="analysis-steps" class="mx-auto max-w-xs space-y-3 text-left">
            <div class="analysis-step flex items-center gap-3 text-sm" data-index="0">
              <div class="step-dot h-5 w-5 shrink-0 rounded-full border-2 border-[#2A2433] bg-[#0e0c0c]"></div>
              <span class="text-[#6b6875]">Checking Gmail inboxes</span>
            </div>
            <div class="analysis-step flex items-center gap-3 text-sm" data-index="1">
              <div class="step-dot h-5 w-5 shrink-0 rounded-full border-2 border-[#2A2433] bg-[#0e0c0c]"></div>
              <span class="text-[#6b6875]">Checking Outlook & Hotmail</span>
            </div>
            <div class="analysis-step flex items-center gap-3 text-sm" data-index="2">
              <div class="step-dot h-5 w-5 shrink-0 rounded-full border-2 border-[#2A2433] bg-[#0e0c0c]"></div>
              <span class="text-[#6b6875]">Checking Yahoo, iCloud, AOL</span>
            </div>
            <div class="analysis-step flex items-center gap-3 text-sm" data-index="3">
              <div class="step-dot h-5 w-5 shrink-0 rounded-full border-2 border-[#2A2433] bg-[#0e0c0c]"></div>
              <span class="text-[#6b6875]">Analyzing email content</span>
            </div>
            <div class="analysis-step flex items-center gap-3 text-sm" data-index="4">
              <div class="step-dot h-5 w-5 shrink-0 rounded-full border-2 border-[#2A2433] bg-[#0e0c0c]"></div>
              <span class="text-[#6b6875]">Generating reputation report</span>
            </div>
          </div>
        </div>
      </div>

      <!-- ==================== STEP 3: RESULTS ==================== -->
      <div id="step-3" class="step-panel hidden">

        <!-- PERFORMANCE REPORT header -->
        <div class="mb-8">
          <div class="flex flex-wrap items-start justify-between gap-5">
            <!-- Left: label + title + sender + status -->
            <div class="flex-1 min-w-0">
              <span class="mb-2 inline-block text-[10px] font-bold uppercase tracking-widest text-[#D2B3F3]">Performance Report</span>
              <h2 class="text-2xl font-bold text-white" id="report-domain-title">Deliverability Report</h2>
              <p id="results-sender" class="mt-0.5 text-xs text-[#6b6875]"></p>
              <p id="score-summary" class="mt-2 max-w-xl text-sm leading-relaxed text-[#C8C1C1]"></p>
            </div>
            <!-- Right: big inbox rate card -->
            <div class="shrink-0 rounded-2xl border border-[#2A2433] bg-[#1A191C] px-8 py-5 text-center" style="min-width:140px;">
              <span id="inbox-pct-center" class="block text-5xl font-black leading-none text-white">—</span>
              <span class="mt-1.5 block text-[10px] font-bold uppercase tracking-widest text-[#6b6875]">Overall Score</span>
              <!-- Hidden elements kept for JS compat -->
              <div class="hidden">
                <svg viewBox="0 0 100 100">
                  <circle cx="50" cy="50" r="38" fill="none" stroke="#2A2433" stroke-width="10"/>
                  <circle id="score-ring" cx="50" cy="50" r="38" fill="none" stroke="#D2B3F3" stroke-width="10" stroke-linecap="round" stroke-dasharray="238.76" stroke-dashoffset="238.76" style="transition:stroke-dashoffset 1.2s ease,stroke 0.5s ease;"/>
                </svg>
                <span id="score-value">—</span>
                <span id="score-badge"></span>
                <svg id="placement-donut" viewBox="0 0 100 100">
                  <circle cx="50" cy="50" r="38" fill="none" stroke="#2A2433" stroke-width="16"/>
                  <circle id="donut-inbox" cx="50" cy="50" r="38" fill="none" stroke="#4ade80" stroke-width="16" stroke-dasharray="238.76" stroke-dashoffset="238.76" style="transition:stroke-dashoffset 1.2s ease 0.2s;"/>
                  <circle id="donut-promo" cx="50" cy="50" r="38" fill="none" stroke="#fbbf24" stroke-width="16" stroke-dasharray="238.76" stroke-dashoffset="238.76" style="transition:stroke-dashoffset 1.2s ease 0.4s;"/>
                  <circle id="donut-spam" cx="50" cy="50" r="38" fill="none" stroke="#f87171" stroke-width="16" stroke-dasharray="238.76" stroke-dashoffset="238.76" style="transition:stroke-dashoffset 1.2s ease 0.6s;"/>
                </svg>
                <span id="inbox-pct">—</span>
                <span id="promo-pct">—</span>
                <span id="spam-pct">—</span>
              </div>
            </div>
          </div>
          <!-- Tracking code + action buttons row -->
          <div class="mt-5 flex flex-wrap items-center gap-3">
            <div class="flex min-w-0 flex-1 items-center gap-3 rounded-xl border border-[#D2B3F3]/20 bg-[#D2B3F3]/5 px-4 py-2.5">
              <svg class="h-3.5 w-3.5 shrink-0 text-[#D2B3F3]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3ZM6 6h.008v.008H6Z"/>
              </svg>
              <span class="text-xs text-[#6b6875]">Tracking code</span>
              <code id="results-tracking-code" class="flex-1 select-all font-mono text-sm font-bold tracking-wide text-[#D2B3F3]"></code>
              <button id="copy-results-code-btn" class="flex items-center gap-1.5 rounded-md border border-[#2A2433] bg-[#1A191C] px-2.5 py-1 text-xs text-[#C8C1C1] transition-all hover:border-[#D2B3F3]/50 hover:text-[#D2B3F3]">
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2m-6 12h8a2 2 0 0 1 2-2v-8a2 2 0 0 1-2-2h-8a2 2 0 0 1-2 2v8a2 2 0 0 1 2 2Z"/></svg>
                Copy
              </button>
            </div>
            <button id="btn-recalculate" class="hidden" style="display:none;">
              <svg id="recalc-icon" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
              Recalculate
            </button>
            <button id="btn-restart" class="flex items-center gap-1.5 rounded-lg border border-[#2A2433] bg-[#1A191C] px-3 py-2 text-xs font-medium text-[#C8C1C1] transition-all hover:border-[#D2B3F3]/40 hover:text-white">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
              New test
            </button>
          </div>
        </div>

        <!-- Sender Reputation — full width -->
        <div class="mb-6 rounded-2xl border border-[#2A2433] bg-[#1A191C] p-6">
          <div class="mb-5 flex items-start justify-between gap-4">
            <div>
              <h3 class="text-base font-semibold text-white">Sender Reputation</h3>
              <p id="rep-domain-subtitle" class="mt-0.5 text-xs text-[#6b6875]">Domain authentication status</p>
            </div>
            <div class="text-right">
              <div id="rep-score-display" class="text-2xl font-black leading-none text-white">—</div>
              <div id="rep-overall-badge" class="hidden mt-0.5 text-[10px] font-bold uppercase tracking-wider"></div>
            </div>
          </div>
          <!-- SPF / DKIM / DMARC as 3 mini tiles -->
          <div id="reputation-main-checks" class="mb-4 grid grid-cols-3 gap-3"></div>
          <!-- MX, blacklist as rows -->
          <div id="reputation-checks" class="space-y-2.5"></div>
        </div>

        <!-- Seed Inbox Granularity -->
        <div class="mb-6 overflow-hidden rounded-2xl border border-[#2A2433] bg-[#1A191C]">
          <div class="border-b border-[#2A2433] px-6 py-5">
            <h3 class="text-base font-semibold italic text-white">Seed Inbox Granularity</h3>
            <p class="mt-0.5 text-xs text-[#6b6875]">Placement result per seed inbox.</p>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-[#2A2433]">
                  <th class="px-6 py-3 text-left text-[10px] font-bold uppercase tracking-wider text-[#6b6875]">Provider</th>
                  <th class="px-6 py-3 text-left text-[10px] font-bold uppercase tracking-wider text-[#6b6875]">Placement</th>
                </tr>
              </thead>
              <tbody id="seed-table-body" class="divide-y divide-[#2A2433]"></tbody>
            </table>
          </div>
          <div id="seed-provider-cards" class="hidden"></div>
        </div>

        <!-- Gated details -->
        <div id="gated-details">

          <!-- Editorial Audit (content analysis) -->
          <div class="mb-5 overflow-hidden rounded-2xl border border-[#2A2433] bg-[#1A191C]">
            <div class="flex items-start justify-between gap-4 border-b border-[#2A2433] px-6 py-5">
              <div>
                <h3 class="text-base font-semibold italic text-white">Editorial Audit</h3>
                <p class="mt-0.5 text-xs text-[#6b6875]">AI-analyzed email content for spam triggers and deliverability friction.</p>
              </div>
