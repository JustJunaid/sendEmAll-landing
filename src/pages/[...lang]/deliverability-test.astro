</style>

<script define:vars={{ SEED_INBOXES_FALLBACK }}>
  const API_BASE = "http://localhost:3001";
  const PROVIDER_COLORS = {
    Gmail: "#EA4335", Outlook: "#0078D4", Yahoo: "#6001D2",
    iCloud: "#555555", ProtonMail: "#6D4AFF", Zoho: "#E42527",
    AOL: "#FF0B00", Hotmail: "#0078D4", Other: "#D2B3F3",
  };

  let testCode = "";
  let testId = "";
  let viewToken = "";    // raw token from POST /tests — must be sent with all subsequent requests
  let reportToken = "";  // raw report token — issued on email submission, unlocks full data
  let seedInboxes = [];
  let testState = {};
  let pollTimer = null;

  // ─── Utility ────────────────────────────────────────────────────────────────

  // Steps: 1=send, 2=analyzing, 3=results
  // Indicator maps: step1→indicator1, step2→indicator1, step3→indicator2
  function showStep(n) {
    document.querySelectorAll(".step-panel").forEach(el => el.classList.add("hidden"));
    document.getElementById(`step-${n}`)?.classList.remove("hidden");
    updateStepIndicator(n === 3 ? 2 : 1);
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  function updateStepIndicator(active) {
    const circles = document.querySelectorAll(".step-circle");
    const labels = document.querySelectorAll(".step-item span");
    const connectors = [
      document.getElementById("connector-1"),
    ];
    circles.forEach((c, i) => {
      const step = i + 1;
      if (step < active) {
        c.className = c.className.replace(/border-\[#2A2433\]|bg-\[#1A191C\]|text-\[#C8C1C1\]|border-\[#D2B3F3\]|bg-\[#D2B3F3\]|text-black/g, "").trim();
        c.classList.add("border-[#4ade80]", "bg-[#4ade80]", "text-black");
        c.innerHTML = `<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/></svg>`;
        labels[i].classList.add("text-[#4ade80]");
        labels[i].classList.remove("text-[#D2B3F3]", "text-[#C8C1C1]");
      } else if (step === active) {
        c.className = c.className.replace(/border-\[#2A2433\]|bg-\[#1A191C\]|text-\[#C8C1C1\]|border-\[#4ade80\]|bg-\[#4ade80\]/g, "").trim();
        c.classList.add("border-[#D2B3F3]", "bg-[#D2B3F3]", "text-black");
        c.textContent = step;
        labels[i].classList.add("text-[#D2B3F3]");
        labels[i].classList.remove("text-[#C8C1C1]", "text-[#4ade80]");
      } else {
        c.classList.remove("border-[#D2B3F3]", "bg-[#D2B3F3]", "text-black", "border-[#4ade80]", "bg-[#4ade80]");
        c.classList.add("border-[#2A2433]", "bg-[#1A191C]", "text-[#C8C1C1]");
        c.textContent = step;
        labels[i].classList.add("text-[#C8C1C1]");
        labels[i].classList.remove("text-[#D2B3F3]", "text-[#4ade80]");
      }
    });
    connectors.forEach((c, i) => {
      if (c) c.style.background = active > i + 1 ? "#4ade80" : "#2A2433";
    });
  }

  async function copyText(text, btn) {
    try {
      await navigator.clipboard.writeText(text);
      const orig = btn.innerHTML;
      btn.innerHTML = btn.innerHTML.replace(/Copy.*/, "Copied!");
      btn.classList.add("text-[#4ade80]", "border-[#4ade80]/40");
      setTimeout(() => { btn.innerHTML = orig; btn.classList.remove("text-[#4ade80]", "border-[#4ade80]/40"); }, 1800);
    } catch {}
  }

  // ─── API helpers ─────────────────────────────────────────────────────────────

  function withToken(path) {
    return viewToken ? `${path}?token=${encodeURIComponent(viewToken)}` : path;
  }

  function withReportToken(path) {
    const base = withToken(path);
    return reportToken ? `${base}&reportToken=${encodeURIComponent(reportToken)}` : base;
  }

  async function apiPost(path, body) {
    const res = await fetch(`${API_BASE}${path}`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
      signal: AbortSignal.timeout(15000),
    });
    if (!res.ok) throw new Error(`API ${res.status}`);
    return res.json();
  }

  async function apiGet(path) {
    const res = await fetch(`${API_BASE}${path}`, { signal: AbortSignal.timeout(15000) });
    if (!res.ok) throw new Error(`API ${res.status}`);
    return res.json();
  }

  // ─── Content Analysis (client-side fallback) ──────────────────────────────

  const SPAM_WORDS = [
    "free","act now","limited time","urgent","cash","money","winner","won",
    "click here","buy now","order now","discount","sale","offer","deal",
    "guarantee","risk-free","no cost","no obligation","no purchase necessary",
    "double your","earn money","extra income","fast cash","financial freedom",
    "get paid","make money","miracle","promise","special promotion",
  ];

  function analyzeContent(subject, body) {
    let score = 100;
    const issues = [];
    const good = [];
    const recs = [];

    const fullText = (subject + " " + body).toLowerCase();
    const foundSpam = SPAM_WORDS.filter(w => fullText.includes(w));
    if (foundSpam.length > 0) {
      score -= 20;
      issues.push(`Contains ${foundSpam.length} spam trigger word${foundSpam.length > 1 ? "s" : ""}: ${foundSpam.slice(0, 4).join(", ")}${foundSpam.length > 4 ? " +" + (foundSpam.length - 4) + " more" : ""}`);
      recs.push(`Remove spam trigger words: ${foundSpam.slice(0, 3).join(", ")}`);
    } else {
      good.push("No spam trigger words detected");
    }

    const hasPersonalization = /\{[a-z_]+\}|{{[a-z_]+}}|\[\[.*?\]\]/i.test(body);
    if (!hasPersonalization) {
      score -= 10;
      issues.push("No personalization tokens found (e.g. {first_name})");
      recs.push("Add personalization — even just a first name improves open rates by 26%");
    } else {
      good.push("Personalization tokens detected");
    }

    const hasUnsubscribe = /unsubscribe|opt.out|opt out|manage preferences/i.test(body);
    if (!hasUnsubscribe) {
      score -= 15;
      issues.push("No unsubscribe link — required by CAN-SPAM & GDPR");
      recs.push("Add an unsubscribe link to comply with CAN-SPAM and GDPR");
    } else {
      good.push("Unsubscribe option found");
    }

    const hasAddress = /\d{1,6}\s+\w+.*(?:st|street|ave|avenue|rd|road|blvd|lane|ln|dr|drive)/i.test(body)
      || /(?:llc|inc|corp|ltd).*\d{4,5}/i.test(body);
    if (!hasAddress) {
      score -= 5;
      issues.push("No physical address detected — recommended for commercial email");
      recs.push("Include your company address in the footer");
    } else {
      good.push("Physical address detected");
    }

    const subjLen = subject.length;
    if (subjLen < 10) {
      score -= 10;
      issues.push(`Subject too short (${subjLen} chars — aim for 20–50)`);
      recs.push("Lengthen your subject line to at least 20 characters");
    } else if (subjLen > 60) {
      score -= 5;
      issues.push(`Subject may be truncated (${subjLen} chars — keep under 60)`);
      recs.push("Shorten subject to under 60 characters to avoid truncation");
    } else {
      good.push(`Subject length is good (${subjLen} chars)`);
    }

    const bodyLen = body.replace(/<[^>]+>/g, "").trim().length;
    if (bodyLen < 50) {
      score -= 10;
      issues.push("Email body is very short — spam filters distrust short emails");
      recs.push("Expand your email body to at least 150 words");
    } else if (bodyLen > 5000) {
      score -= 5;
      issues.push("Very long email body may reduce engagement");
    } else {
      good.push(`Email body length is appropriate (${bodyLen} chars)`);
    }

    const hasLinks = /<a\s/i.test(body) || /https?:\/\//i.test(body);
    const textToHtmlRatio = bodyLen / Math.max(body.length, 1);
    if (textToHtmlRatio < 0.2 && body.length > 200) {
      score -= 5;
      issues.push("Low text-to-HTML ratio — image-heavy emails land in spam more often");
      recs.push("Increase the text-to-HTML ratio; aim for at least 60% text content");
    } else if (hasLinks) {
      good.push("Email contains links (good for engagement)");
    }

    score = Math.max(0, Math.min(100, score));
    return { score, issues, good, recs };
  }

  // ─── Render results ───────────────────────────────────────────────────────

  function getAuditSeverity(msg) {
    if (/spam|trigger|blacklist|phish|block|unsubscrib/i.test(msg)) return "high";
    if (/link|ssl|certificate|image|ratio|address|physical/i.test(msg)) return "medium";
    return "low";
  }

  function auditIssueRow(msg, isGood) {
    if (isGood) {
      return `
        <div class="flex items-center gap-4 px-6 py-3.5">
          <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#4ade80]/10 border border-[#4ade80]/20">
            <svg class="h-3 w-3 text-[#4ade80]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/></svg>
          </div>
          <p class="text-sm text-[#C8C1C1]">${msg}</p>
        </div>
      `;
    }
    const sev = getAuditSeverity(msg);
    const [sevLabel, sevCss, iconColor, iconBg] = sev === "high"
      ? ["HIGH SEVERITY",  "color:#f87171;background:rgba(248,113,113,0.12);border:1px solid rgba(248,113,113,0.3);", "#f87171", "bg-red-500/10 border-red-500/20"]
      : sev === "medium"
      ? ["MEDIUM SEVERITY","color:#fbbf24;background:rgba(251,191,36,0.12);border:1px solid rgba(251,191,36,0.3);",  "#fbbf24", "bg-amber-500/10 border-amber-500/20"]
      : ["LOW SEVERITY",   "color:#60a5fa;background:rgba(96,165,250,0.12);border:1px solid rgba(96,165,250,0.3);",  "#60a5fa", "bg-blue-500/10 border-blue-500/20"];
    const iconSvg = sev === "high"
      ? `<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="color:${iconColor}"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>`
      : sev === "medium"
      ? `<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:${iconColor}"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"/></svg>`
      : `<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:${iconColor}"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/></svg>`;
    return `
      <div class="flex items-center gap-4 px-6 py-3.5">
        <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border ${iconBg}">${iconSvg}</div>
        <div class="flex flex-1 min-w-0 flex-wrap items-center gap-2">
          <span class="text-sm font-semibold text-white">${msg}</span>
          <span class="inline-flex shrink-0 rounded border px-1.5 py-0.5 text-[9px] font-bold uppercase tracking-wider" style="${sevCss}">${sevLabel}</span>
        </div>
      </div>
    `;
  }

  function renderContentChecks(issues, good) {
    const container = document.getElementById("content-checks");
    container.innerHTML = [...good.map(m => auditIssueRow(m, true)), ...issues.map(m => auditIssueRow(m, false))].join("");

    // Content score badge
    const total = issues.length + good.length;
    const badge = document.getElementById("content-score-badge");
    if (badge && total > 0) {
      const pct = Math.round((good.length / total) * 100);
      badge.textContent = `${pct}% clean`;
      badge.classList.remove("hidden");
      if (pct >= 80) badge.style.cssText = "display:inline-flex;background:rgba(74,222,128,0.1);color:#4ade80;border:1px solid rgba(74,222,128,0.3);";
      else if (pct >= 50) badge.style.cssText = "display:inline-flex;background:rgba(251,191,36,0.1);color:#fbbf24;border:1px solid rgba(251,191,36,0.3);";
      else badge.style.cssText = "display:inline-flex;background:rgba(248,113,113,0.1);color:#f87171;border:1px solid rgba(248,113,113,0.3);";
    }
  }

  function renderReputationChecks(senderEmail, reputation) {
    const domain = (reputation?.domain || senderEmail.split("@")[1] || senderEmail || "yourdomain.com").toLowerCase();

    // Build checks from live data when available, otherwise show pending state
    const checks = reputation ? buildLiveReputationChecks(domain, reputation) : buildPendingReputationChecks(domain);

    // First 3 (SPF, DKIM, DMARC) → mini tile cards
    const mainContainer = document.getElementById("reputation-main-checks");
    if (mainContainer) {
      mainContainer.innerHTML = checks.slice(0, 3).map(c => reputationMiniCard(c)).join("");
    }

    // Remaining (MX, Blacklist, Domain age) → list rows
    const container = document.getElementById("reputation-checks");
    if (container) {
      container.innerHTML = checks.slice(3).map(c => reputationCheckRow(c)).join("");
    }

    // Update domain subtitle
    const sub = document.getElementById("rep-domain-subtitle");
    if (sub && domain !== "yourdomain.com") sub.textContent = `Real-time health for ${domain}`;

    // Overall score + badge
    const failed = checks.filter(c => c.passed != null && c.passed === false).length;
    const passed = checks.filter(c => c.passed === true).length;
    const total = checks.length;
    const scoreNum = total > 0 ? Math.round((passed / total) * 100) : null;

    const scoreEl = document.getElementById("rep-score-display");
    if (scoreEl && scoreNum !== null) {
      const scoreColor = scoreNum >= 80 ? "#4ade80" : scoreNum >= 50 ? "#fbbf24" : "#f87171";
      scoreEl.innerHTML = `<span style="color:${scoreColor}">${scoreNum}</span><span style="font-size:1rem;color:#6b6875;font-weight:500;">/100</span>`;
    }

    const badge = document.getElementById("rep-overall-badge");
    if (badge && reputation) {
      badge.classList.remove("hidden");
      if (failed === 0) {
        badge.textContent = "EXCELLENT STATUS";
        badge.style.cssText = "display:block;color:#4ade80;";
      } else if (failed >= 2) {
        badge.textContent = `${failed} ISSUES DETECTED`;
        badge.style.cssText = "display:block;color:#f87171;";
      } else {
        badge.textContent = `${failed} ISSUE DETECTED`;
        badge.style.cssText = "display:block;color:#fbbf24;";
      }
    }
  }

  function reputationMiniCard(c) {
    let iconHtml, bg, border, textColor;
    if (c.passed == null) {
      iconHtml = `<div class="h-3.5 w-3.5 animate-pulse rounded-full bg-[#6b6875]"></div>`;
      bg = "bg-[#0e0c0c]"; border = "border-[#2A2433]"; textColor = "text-[#6b6875]";
    } else if (c.passed) {
      iconHtml = `<svg class="h-3.5 w-3.5 text-[#4ade80]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/></svg>`;
      bg = "bg-[#4ade80]/5"; border = "border-[#4ade80]/20"; textColor = "text-white";
    } else {
      iconHtml = `<svg class="h-3.5 w-3.5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>`;
      bg = "bg-red-500/5"; border = "border-red-500/20"; textColor = "text-white";
    }
    const shortDesc = c.desc.length > 55 ? c.desc.slice(0, 52) + "…" : c.desc;
    return `
      <div class="rounded-xl border ${border} ${bg} p-4">
        <div class="mb-2 flex items-center justify-between">
          <span class="text-xs font-bold uppercase tracking-wide ${textColor}">${c.label}</span>
          <div class="flex h-5 w-5 items-center justify-center rounded-full bg-[#1A191C]">${iconHtml}</div>
        </div>
        <p class="text-[11px] leading-snug text-[#6b6875]">${shortDesc}</p>
      </div>
    `;
  }

  function derivePlacementPcts(placement, seedResults) {
    if (placement?.total > 0) {
      const t = placement.total;
      const inboxPct = Math.round((placement.inbox / t) * 100);
      const spamPct  = Math.round((placement.spam  / t) * 100);
      return { inboxPct, spamPct, promoPct: Math.max(0, 100 - inboxPct - spamPct) };
    }
    if (Array.isArray(seedResults) && seedResults.length > 0) {
      const withPl = seedResults.filter(r => r.placementStatus || r.placement);
      if (withPl.length > 0) {
        const t = withPl.length;
        const pl = r => r.placementStatus || r.placement || "";
        const inbox = withPl.filter(r => pl(r) === "inbox").length;
        const spam  = withPl.filter(r => pl(r) === "spam").length;
        const promo = withPl.filter(r => pl(r) === "promotions" || pl(r) === "promo").length;
        const inboxPct = Math.round((inbox / t) * 100);
        const spamPct  = Math.round((spam  / t) * 100);
        const promoPct = Math.round((promo / t) * 100);
        return { inboxPct, spamPct, promoPct };
      }
    }
    return null; // no data yet
  }

  function extractReputationRecs(reputation) {
    if (!reputation) return [];
    const recs = [];
    // Only flag checks that explicitly failed (passed === false), not pending (null/undefined)
    if (reputation.spf?.passed === false)   recs.push("Add an SPF record (v=spf1 include:youresp.com ~all) — this authorizes your ESP to send on your behalf");
    if (reputation.dkim?.passed === false)  recs.push("Enable DKIM signing in your ESP settings and add the provided CNAME records to your DNS");
    if (reputation.dmarc?.passed === false) recs.push("Add a DMARC policy starting with p=none to monitor, then upgrade to p=quarantine once SPF & DKIM pass consistently");
    if (reputation.mx?.passed === false)    recs.push("Fix your MX records — without them, replies can't reach your domain");
    if (reputation.blacklist?.isBlacklisted) recs.push(`Your domain appears on a blacklist (${(reputation.blacklist.reasons || []).slice(0,2).join(", ")}). Submit removal requests at each RBL's delisting page`);
    return recs;
  }

  function buildLiveReputationChecks(domain, rep) {
    // Blacklist — guard against missing data
    const bl = rep.blacklist || {};
    const blacklistPassed = !bl.isBlacklisted;
    const blacklistDesc = blacklistPassed
      ? `${domain} is not listed on Spamhaus, SURBL, or URIBL.`
      : `Listed on: ${(bl.reasons || []).slice(0, 2).join("; ")}`;

    // Each check — use optional chaining so a missing sub-object shows as pending (null)
    // rather than crashing or rendering as failed
    const spf   = rep.spf   || null;
    const dkim  = rep.dkim  || null;
    const dmarc = rep.dmarc || null;
    const mx    = rep.mx    || null;

    return [
      {
        label: "SPF record",
        passed: spf != null ? (spf.passed ?? null) : null,
        desc: spf?.details || (spf?.passed === false
          ? (spf?.record ? "SPF record found but failed validation — check your include chain" : "SPF record missing or invalid")
          : `Checking TXT records for ${domain}…`),
        record: spf?.record,
      },
      {
        label: "DKIM signature",
        passed: dkim != null ? (dkim.passed ?? null) : null,
        desc: dkim?.details || (dkim?.passed === false
          ? (dkim?.record ? "DKIM record found but signature validation failed — verify your ESP signing settings" : "No valid DKIM record found for common selectors")
          : `Checking DKIM selectors for ${domain}…`),
        record: dkim?.record,
      },
      {
        label: "DMARC policy",
        passed: dmarc != null ? (dmarc.passed ?? null) : null,
        desc: dmarc?.details || (dmarc?.passed === false
          ? (dmarc?.record ? "DMARC record found but policy failed validation — check your policy syntax" : "DMARC record missing or invalid")
          : `Checking _dmarc.${domain}…`),
        record: dmarc?.record,
      },
      {
        label: "MX records",
        passed: mx != null ? (mx.passed ?? null) : null,
        desc: mx?.details || (mx?.passed === false
          ? (mx?.record ? "MX record found but failed validation — verify your mail server is reachable" : "No MX records found — replies can't reach this domain")
          : `Checking MX records for ${domain}…`),
        record: mx?.record,
      },
      { label: "Blacklist status", passed: rep.blacklist != null ? blacklistPassed : null, desc: rep.blacklist != null ? blacklistDesc : "Checking Spamhaus, SURBL, URIBL…" },
    ];
  }

  function buildPendingReputationChecks(domain) {
    return [
      { label: "SPF record",      passed: null, desc: `Checking TXT records for ${domain}…` },
      { label: "DKIM signature",  passed: null, desc: "Checking common DKIM selectors…" },
      { label: "DMARC policy",    passed: null, desc: `Checking _dmarc.${domain}…` },
      { label: "MX records",      passed: null, desc: `Checking MX records for ${domain}…` },
      { label: "Blacklist status", passed: null, desc: "Checking Spamhaus, SURBL, URIBL…" },
    ];
  }

  function reputationCheckRow(c) {
    let iconHtml, borderClass;
    if (c.passed == null) {
      // Pending / unknown (null OR undefined treated the same)
      iconHtml = `<div class="h-3 w-3 animate-pulse rounded-full bg-[#6b6875]"></div>`;
      borderClass = "border-[#2A2433]";
    } else if (c.passed) {
      iconHtml = `<svg class="h-3 w-3 text-[#4ade80]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/></svg>`;
      borderClass = "border-[#4ade80]/20";
    } else {
      iconHtml = `<svg class="h-3 w-3 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>`;
      borderClass = "border-red-500/20";
    }

    const bgClass = c.passed == null ? "bg-[#0e0c0c]"
                  : c.passed          ? "bg-[#4ade80]/5"
                  : "bg-red-500/5";

    const recordPill = c.record
      ? `<p class="mt-1 truncate font-mono text-xs text-[#6b6875]" title="${c.record}">${c.record.substring(0, 60)}${c.record.length > 60 ? "…" : ""}</p>`
      : "";

    return `
      <div class="flex items-start gap-3 rounded-lg border ${borderClass} ${bgClass} px-4 py-3.5">
        <div class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[#1A191C]">
          ${iconHtml}
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-medium text-white">${c.label}</p>
          <p class="mt-0.5 text-xs text-[#6b6875]">${c.desc}</p>
          ${recordPill}
        </div>
      </div>
    `;
  }

  function renderScoreRing(score) {
    const circ = 238.76;
    const offset = circ - (score / 100) * circ;
    const ring = document.getElementById("score-ring");
    ring.style.strokeDashoffset = offset;

    let color, tier, summary, statusWord;
    if (score >= 75) {
      color = "#4ade80"; tier = "Excellent"; statusWord = "Optimal";
      summary = `Your placement is <strong style="color:#4ade80">Optimal</strong>. Authentication checks pass and inbox rate is strong.`;
    } else if (score >= 55) {
      color = "#fbbf24"; tier = "Fair"; statusWord = "Fair";
      summary = `Your placement is <strong style="color:#fbbf24">Fair</strong>. Minor issues detected — review the checks below to improve inbox rate.`;
    } else if (score >= 35) {
      color = "#fb923c"; tier = "At Risk"; statusWord = "At Risk";
      summary = `Your placement is <strong style="color:#fb923c">At Risk</strong>. High spam rate detected — address the flagged issues before sending at scale.`;
    } else {
      color = "#f87171"; tier = "Critical"; statusWord = "Critical";
      summary = `Your placement is <strong style="color:#f87171">Critical</strong>. Most emails are landing in spam. Fix authentication and content issues immediately.`;
    }
    ring.style.stroke = color;
    document.getElementById("score-value").textContent = score;
    const badge = document.getElementById("score-badge");
    badge.textContent = tier;
    badge.style.background = color + "20";
    badge.style.color = color;
    badge.style.border = `1px solid ${color}40`;
    const summaryEl = document.getElementById("score-summary");
    if (summaryEl) summaryEl.innerHTML = summary;

    // Show overall score in the prominent inbox-rate card
    const centerEl = document.getElementById("inbox-pct-center");
    if (centerEl) {
      centerEl.textContent = score + "%";
      centerEl.style.color = color;
    }
  }

  function renderPlacementDonut(inbox, promo, spam) {
    const circ = 238.76;
    const inboxArc = (inbox / 100) * circ;
    const promoArc = (promo / 100) * circ;
    const spamArc = (spam / 100) * circ;

    const dInbox = document.getElementById("donut-inbox");
    const dPromo = document.getElementById("donut-promo");
    const dSpam = document.getElementById("donut-spam");

    dInbox.style.strokeDasharray = `${inboxArc} ${circ}`;
    dInbox.style.strokeDashoffset = "0";

    dPromo.style.strokeDasharray = `${promoArc} ${circ}`;
    dPromo.style.strokeDashoffset = `-${inboxArc}`;

    dSpam.style.strokeDasharray = `${spamArc} ${circ}`;
    dSpam.style.strokeDashoffset = `-${inboxArc + promoArc}`;

    document.getElementById("inbox-pct").textContent = inbox + "%";
    document.getElementById("promo-pct").textContent = promo + "%";
    document.getElementById("spam-pct").textContent = spam + "%";
  }

  function recItem(text) {
    return `<li class="flex items-start gap-2.5 rounded-lg border border-[#2A2433] bg-[#0e0c0c] px-4 py-3 text-sm">
      <svg class="mt-0.5 h-4 w-4 shrink-0 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
      </svg>
      <span class="leading-relaxed text-[#C8C1C1]">${text}</span>
    </li>`;
  }

  function renderRecommendations(contentRecs, reputationRecs, deliverabilityRecs) {
    const section = document.getElementById("recommendations-section");
    section.classList.add("hidden");

    // Merge all: deliverability (high) → reputation (high/med) → content (med/low)
    const all = [
      ...(deliverabilityRecs || []).map(t => ({ text: t, priority: "high" })),
      ...(reputationRecs || []).map(t => ({ text: t, priority: "high" })),
      ...(contentRecs || []).map((t, i) => ({ text: t, priority: i === 0 ? "medium" : "low" })),
    ];
    if (!all.length) return;

    const list = document.getElementById("all-recs-list");
    if (list) {
      list.innerHTML = all.map((r, i) => {
        const num = String(i + 1).padStart(2, "0");
        const [priLabel, priCss] = r.priority === "high"
          ? ["High Priority",   "color:#f87171;background:rgba(248,113,113,0.12);border:1px solid rgba(248,113,113,0.25);"]
          : r.priority === "medium"
          ? ["Medium Priority", "color:#fbbf24;background:rgba(251,191,36,0.12);border:1px solid rgba(251,191,36,0.25);"]
          : ["Low Priority",    "color:#60a5fa;background:rgba(96,165,250,0.12);border:1px solid rgba(96,165,250,0.25);"];
        const title = r.text.split(/[—.\-]/)[0].trim().slice(0, 60);
        const desc = r.text;
        const isFirst = i === 0;
        return `
          <li class="rec-accordion-item" data-open="${isFirst}">
            <div class="flex cursor-pointer items-center gap-4 px-6 py-4 transition-colors hover:bg-[#0e0c0c]"
                 onclick="this.closest('li').dataset.open=this.closest('li').dataset.open==='true'?'false':'true';this.closest('li').querySelector('.rec-body').style.display=this.closest('li').dataset.open==='true'?'block':'none';this.querySelector('.rec-chevron').style.transform=this.closest('li').dataset.open==='true'?'rotate(180deg)':'';">
              <span class="shrink-0 text-xs font-bold text-[#6b6875]">${num}</span>
              <div class="flex flex-1 min-w-0 flex-wrap items-center gap-2">
                <span class="text-sm font-semibold text-white">${title}</span>
                <span class="inline-flex rounded border px-1.5 py-0.5 text-[9px] font-bold uppercase tracking-wider" style="${priCss}">${priLabel}</span>
              </div>
              <svg class="rec-chevron h-4 w-4 shrink-0 text-[#6b6875] transition-transform" style="${isFirst ? "transform:rotate(180deg)" : ""}" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7"/>
              </svg>
            </div>
            <div class="rec-body px-6 pb-4 pt-0" style="display:${isFirst ? "block" : "none"}">
              <p class="text-sm leading-relaxed text-[#C8C1C1]/80">${desc}</p>
            </div>
          </li>
        `;
      }).join("");
    }

    // Also populate hidden categorized lists (unlockGate compat)
    const delivList = document.getElementById("deliverability-recs-list");
    if (delivList) delivList.innerHTML = (deliverabilityRecs || []).map(recItem).join("");
    const repList = document.getElementById("reputation-recs-list");
    if (repList) repList.innerHTML = (reputationRecs || []).map(recItem).join("");
    const contentList = document.getElementById("content-recs-list");
    if (contentList) contentList.innerHTML = (contentRecs || []).map(recItem).join("");

    // Only show section if email capture is already hidden (gate unlocked)
    const captureCard = document.getElementById("email-capture-card");
    if (!captureCard || captureCard.style.display === "none") {
      section.classList.remove("hidden");
    }

    // Wire up expand all button
    const expandBtn = document.getElementById("btn-expand-all");
    if (expandBtn && !expandBtn._wired) {
      expandBtn._wired = true;
      expandBtn.addEventListener("click", () => {
        document.querySelectorAll(".rec-accordion-item").forEach(item => {
          item.dataset.open = "true";
          const body = item.querySelector(".rec-body");
          const chev = item.querySelector(".rec-chevron");
          if (body) body.style.display = "block";
          if (chev) chev.style.transform = "rotate(180deg)";
        });
      });
    }
  }

  function renderSeedTable(inboxes, seedResults) {
    const displayInboxes = Array.isArray(inboxes) && inboxes.length > 0 ? inboxes : (seedResults ?? []);
    const tbody = document.getElementById("seed-table-body");
    if (!tbody) return;

    tbody.innerHTML = displayInboxes.map(s => {
      const provider = s.provider || guessProvider(s.email);
      const color = PROVIDER_COLORS[provider] || PROVIDER_COLORS.Other;
      const fallback = Array.isArray(seedResults) ? seedResults.find(r => r.email === s.email) : null;
      const pl = s.placementStatus || s.placement || fallback?.placementStatus || fallback?.placement || null;

      let badgeHtml;
      if (!pl) {
        badgeHtml = `<span class="inline-flex rounded border border-[#2A2433] bg-[#0e0c0c] px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-[#6b6875]">Pending</span>`;
      } else if (pl === "inbox") {
        const label = provider === "Gmail" ? "Inbox (Primary)" : "Inbox";
        badgeHtml = `<span class="inline-flex rounded border border-[#4ade80]/30 bg-[#4ade80]/10 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-[#4ade80]">${label}</span>`;
      } else if (pl === "promotions" || pl === "promo") {
        badgeHtml = `<span class="inline-flex rounded border border-[#fbbf24]/30 bg-[#fbbf24]/10 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-[#fbbf24]">Promotions</span>`;
      } else if (pl === "spam") {
        badgeHtml = `<span class="inline-flex rounded border border-red-500/30 bg-red-500/10 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-red-400">Spam</span>`;
      } else {
        badgeHtml = `<span class="inline-flex rounded border border-[#2A2433] bg-[#0e0c0c] px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-[#6b6875]">${pl}</span>`;
      }

      return `<tr class="transition-colors hover:bg-[#0e0c0c]">
        <td class="px-6 py-4">
          <div class="flex items-center gap-3">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg" style="background:${color}18;border:1px solid ${color}30;">
              <span class="h-2 w-2 rounded-full" style="background:${color};"></span>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-white">${provider}</p>
              <p class="font-mono text-[11px] text-[#6b6875] truncate max-w-[200px]">${s.email}</p>
            </div>
          </div>
        </td>
        <td class="px-6 py-4">${badgeHtml}</td>
      </tr>`;
    }).join("");
  }

  function providerCard(provider, inboxPct, spamPct, checking) {
    const color = PROVIDER_COLORS[provider] || PROVIDER_COLORS.Other;
    let pctDisplay, statusLabel, statusStyle, barColor, barPct;
    if (checking || inboxPct === null) {
      pctDisplay = "—";
      statusLabel = "Propagating tests";
      statusStyle = "color:#6b6875;";
      barColor = "#2A2433";
      barPct = 0;
    } else if (spamPct > 30) {
      pctDisplay = `${spamPct}%`;
      statusLabel = "Spam filtered";
      statusStyle = "color:#f87171;";
      barColor = "#f87171";
      barPct = spamPct;
    } else if (spamPct > 0 || inboxPct < 80) {
      pctDisplay = `${inboxPct}%`;
      statusLabel = "Partial spam filtered";
      statusStyle = "color:#fbbf24;";
      barColor = "#fbbf24";
      barPct = inboxPct;
    } else {
      pctDisplay = `${inboxPct}%`;
      statusLabel = "Inbox placement";
      statusStyle = "color:#4ade80;";
      barColor = "#4ade80";
      barPct = inboxPct;
    }
    // Status icon
    const icon = checking || inboxPct === null
      ? `<svg class="h-5 w-5 text-[#6b6875]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>`
      : spamPct > 30
      ? `<svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>`
      : spamPct > 0 || inboxPct < 80
      ? `<svg class="h-5 w-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>`
      : `<svg class="h-5 w-5" style="color:${color}" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3.75H6.912a2.25 2.25 0 0 0-2.15 1.588L2.35 13.177a2.25 2.25 0 0 0-.1.661V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 0 0-2.15-1.588H15M2.25 13.5h3.86a2.25 2.25 0 0 1 2.012 1.244l.256.512a2.25 2.25 0 0 0 2.013 1.244h3.218a2.25 2.25 0 0 0 2.013-1.244l.256-.512a2.25 2.25 0 0 1 2.013-1.244h3.859M12 3v8.25m0 0-3-3m3 3 3-3"/></svg>`;
    return `
      <div class="rounded-2xl border border-[#2A2433] bg-[#1A191C] p-5">
        <div class="mb-3 flex items-center justify-between">
          <span class="text-sm font-semibold text-white">${provider}</span>
          ${icon}
        </div>
        <div class="mb-1">
          <span class="text-4xl font-black leading-none" style="${pctDisplay === "—" ? "color:#6b6875;" : "color:#fff;"}">${pctDisplay}</span>
        </div>
        <p class="mb-3 text-[10px] font-bold uppercase tracking-wider" style="${statusStyle}">${statusLabel}</p>
        <div class="h-1 w-full overflow-hidden rounded-full bg-[#2A2433]">
          <div class="h-full rounded-full transition-all duration-700" style="width:${barPct}%;background:${barColor};"></div>
        </div>
      </div>
    `;
  }

  // ─── Provider color helper ────────────────────────────────────────────────

  function guessProvider(email) {
    const domain = (email.split("@")[1] || "").toLowerCase();
    if (domain.includes("gmail"))    return "Gmail";
    if (domain.includes("outlook") || domain.includes("hotmail") || domain.includes("live")) return "Outlook";
    if (domain.includes("yahoo"))    return "Yahoo";
    if (domain.includes("icloud") || domain.includes("me.com")) return "iCloud";
    if (domain.includes("proton") || domain.includes("pm.me"))  return "ProtonMail";
    if (domain.includes("zoho"))     return "Zoho";
    if (domain.includes("aol"))      return "AOL";
    return "Other";
  }

  function renderInboxList(inboxes) {
    const list = document.getElementById("inbox-list");
    list.innerHTML = inboxes.map(s => {
      const color = PROVIDER_COLORS[s.provider] || PROVIDER_COLORS.Other;
      return `
        <div class="group flex items-center gap-3 rounded-lg border border-[#2A2433] bg-[#0e0c0c] px-4 py-3 transition-all hover:border-[#D2B3F3]/20">
          <div class="flex h-2.5 w-2.5 shrink-0 rounded-full" style="background:${color};"></div>
          <span class="flex-1 font-mono text-sm text-[#C8C1C1] select-all">${s.email}</span>
          <span class="shrink-0 rounded-full border border-[#2A2433] px-2 py-0.5 text-xs" style="color:${color}; border-color:${color}30; background:${color}10;">${s.provider}</span>
        </div>
      `;
    }).join("");
    document.getElementById("inboxes-loading").classList.add("hidden");
    list.classList.remove("hidden");
  }

  // ─── Analyzing animation ──────────────────────────────────────────────────

  function runAnalysisAnimation(callback) {
    const steps = document.querySelectorAll(".analysis-step");
    let i = 0;
    const advance = () => {
      if (i > 0) {
        steps[i - 1].classList.remove("active");
        steps[i - 1].classList.add("done");
        const dot = steps[i - 1].querySelector(".step-dot");
        dot.innerHTML = `<svg class="h-3 w-3 text-black" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/></svg>`;
      }
      if (i < steps.length) {
        steps[i].classList.add("active");
        i++;
        setTimeout(advance, 900 + Math.random() * 600);
      } else {
        setTimeout(callback, 400);
      }
    };
    advance();
  }

  // ─── Gate helpers ─────────────────────────────────────────────────────────

  let aiFixSubject = "";
  let aiFixBody = "";
  let aiFixStarted = false;

  // Called as soon as results complete with spam > 20% — runs in background.
  async function fetchAiFix() {
    if (aiFixStarted || !testId) return;
    aiFixStarted = true;
    try {
      const data = await apiPost(withToken(`/open/deliverability/tests/${testId}/generate-fix`), {});
      aiFixSubject = data.subject || "";
      aiFixBody = data.body || "";
      document.getElementById("ai-fix-loading")?.classList.add("hidden");
      document.getElementById("ai-subject-text").textContent = aiFixSubject;
      document.getElementById("ai-body-text").textContent = aiFixBody;
      document.getElementById("ai-fix-content")?.classList.remove("hidden");
    } catch {
      document.getElementById("ai-fix-section")?.classList.add("hidden");
    }
  }

  function unlockGate(spamPct) {
    // Show recommendations section if any category has items
    const recSection = document.getElementById("recommendations-section");
    const hasRecs = ["deliverability-recs-list","reputation-recs-list","content-recs-list"]
      .some(id => (document.getElementById(id)?.children.length ?? 0) > 0);
    if (recSection && hasRecs) recSection.classList.remove("hidden");
    // Hide email capture card
    document.getElementById("report-form")?.classList.add("hidden");
    const card = document.getElementById("email-capture-card");
    if (card) card.style.display = "none";
    // Show AI fix section
    if (testId) {
      document.getElementById("ai-fix-section")?.classList.remove("hidden");
      if (!aiFixStarted) fetchAiFix();
    }
  }

  // ─── Wire up interactions ─────────────────────────────────────────────────

  function resetState() {
    testCode    = "";
    testId      = "";
    viewToken   = "";
    reportToken = "";
    seedInboxes = [];
    testState = {};
    aiFixStarted = false;
    aiFixSubject = "";
    aiFixBody = "";
    if (pollTimer) { clearTimeout(pollTimer); pollTimer = null; }
    // Reset analysis steps
    document.querySelectorAll(".analysis-step").forEach(s => {
      s.classList.remove("active", "done");
      s.querySelector(".step-dot").innerHTML = "";
    });
    // Re-lock gated section
    // Reset recommendation categories
    ["deliverability-recs-section","reputation-recs-section","content-recs-section"].forEach(id => {
      document.getElementById(id)?.classList.add("hidden");
    });
    // Reset reputation badge
    const repBadge = document.getElementById("rep-overall-badge");
    if (repBadge) { repBadge.classList.add("hidden"); repBadge.style.cssText = ""; }
    const contentBadge = document.getElementById("content-score-badge");
    if (contentBadge) { contentBadge.classList.add("hidden"); contentBadge.style.cssText = ""; }
    const captureCard = document.getElementById("email-capture-card");
    if (captureCard) captureCard.style.display = "";
    document.getElementById("report-form")?.classList.remove("hidden");
    document.getElementById("report-success")?.classList.add("hidden");
    document.getElementById("report-email").value = "";
    document.getElementById("ai-fix-section")?.classList.add("hidden");
    document.getElementById("ai-fix-loading")?.classList.remove("hidden");
    document.getElementById("ai-fix-content")?.classList.add("hidden");
  }

  function generateLocalCode() {
    const chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
    let c = "SEA-TEST-";
    for (let i = 0; i < 8; i++) c += chars[Math.floor(Math.random() * chars.length)];
    return c;
  }

  async function initializeTest(prefillSubject, prefillBody) {
    // Show loading state
    document.getElementById("tracking-code").textContent = "Generating…";
    document.getElementById("inboxes-loading").classList.remove("hidden");
    document.getElementById("inbox-list").classList.add("hidden");

    const body = {};
    if (prefillSubject) body.subject = prefillSubject;
    if (prefillBody) body.body = prefillBody;

    try {
      const data = await apiPost("/open/deliverability/tests", body);
      testId     = data.id;
      testCode   = data.trackingCode;
      viewToken  = data.viewToken || "";
      testState = { subject: prefillSubject || "", body: prefillBody || "", contentAnalysis: data.contentAnalysis };
      seedInboxes = (data.seedInboxes?.length ? data.seedInboxes : SEED_INBOXES_FALLBACK).map(s => ({
        ...s, provider: s.provider || guessProvider(s.email),
      }));
    } catch {
      testId    = "";
      testCode  = generateLocalCode();
      testState = { subject: prefillSubject || "", body: prefillBody || "", contentAnalysis: null };
      seedInboxes = SEED_INBOXES_FALLBACK;
    }

    document.getElementById("tracking-code").textContent = testCode;
    showStep(1);
    renderInboxList(seedInboxes);
  }

  document.addEventListener("DOMContentLoaded", () => {

    // Only create a fresh test if NOT loading from an emailed link (?testId= in URL)
    if (!new URLSearchParams(window.location.search).get("testId")) {
      initializeTest();
    }

    // Copy tracking code
    document.getElementById("copy-code-btn").addEventListener("click", function() {
      copyText(testCode, this);
    });

    // Copy all seed addresses
    document.getElementById("copy-all-btn").addEventListener("click", function() {
      copyText(seedInboxes.map(s => s.email).join(", "), this);
    });

    // Shared: mark sent → poll → render results
    async function runCheck() {
      showStep(2);

      // Reset analysis steps animation
      document.querySelectorAll(".analysis-step").forEach(s => {
        s.classList.remove("active", "done");
        s.querySelector(".step-dot").innerHTML = "";
      });

      if (testId) {
        apiPost(withToken(`/open/deliverability/tests/${testId}/mark-sent`), {}).catch(() => {});
      }

      runAnalysisAnimation(async () => {
        let results = null;

        if (testId) {
          for (let attempt = 0; attempt < 18; attempt++) {
            await new Promise(r => setTimeout(r, 5000));
            try {
              const data = await apiGet(withToken(`/open/deliverability/tests/${testId}/results`));
              if (data.status === "completed") { results = data; break; }
            } catch {}
          }
        }

        let contentAnalysis = results?.contentAnalysis || testState.contentAnalysis;
        if (!contentAnalysis) {
          contentAnalysis = analyzeContent(testState.subject, testState.body);
        }
        const { score, issues = [], positives = [], recommendations = [] } = contentAnalysis;

        const _pcts = derivePlacementPcts(results?.placement, results?.seedResults);
        let inboxPct = _pcts?.inboxPct ?? 0;
        let spamPct  = _pcts?.spamPct  ?? 0;
        let promoPct = _pcts?.promoPct ?? 0;

        const overallScore = results?.overallScore ?? Math.round(score * 0.6 + (inboxPct / 100) * 40);

        const domain = results?.senderReputation?.domain || results?.contactEmail?.split("@")[1] || "";
        const senderLabel = domain ? `Sender: ${results?.contactEmail || domain} · Test ${testCode}` : testCode ? `Test ${testCode}` : "";
        document.getElementById("results-sender").textContent = senderLabel;
        const titleEl = document.getElementById("report-domain-title");
        if (titleEl && domain) titleEl.textContent = `Report: ${domain}`;
        const resultsCode = document.getElementById("results-tracking-code");
        if (resultsCode) resultsCode.textContent = testCode;

        testState.spamPct = spamPct;

        // Build categorized recommendations
        const reputationRecs = extractReputationRecs(results?.senderReputation ?? null);
        const deliverabilityRecs = [];
        if (spamPct > 30) deliverabilityRecs.push(`${spamPct}% of your emails landed in spam. Fix SPF/DKIM/DMARC immediately and remove spam trigger words from your content.`);
        else if (spamPct > 15) deliverabilityRecs.push(`${spamPct}% of emails hit spam. Review your sender reputation checks and remove any trigger words from your content.`);
        if (inboxPct < 50) deliverabilityRecs.push("Less than half your emails reach the primary inbox. Review all authentication checks and consider warming up on a fresh domain.");
        if (promoPct > 40) deliverabilityRecs.push("Over 40% of emails land in Promotions. Use plain text, reduce links, and write in a personal one-to-one tone.");

        renderScoreRing(Math.max(0, Math.min(100, overallScore)));
        renderPlacementDonut(inboxPct, Math.max(0, promoPct), spamPct);
        renderContentChecks(issues, positives);
        renderReputationChecks(testState.email || "", results?.senderReputation ?? null);
        renderRecommendations(recommendations, reputationRecs, deliverabilityRecs);
        // Prefer seed inboxes returned with results (actual inboxes used) over the creation-time list
        if (results?.seedInboxes?.length) seedInboxes = results.seedInboxes.map(s => ({ ...s, provider: s.provider || guessProvider(s.email) }));
        renderSeedTable(seedInboxes?.length ? seedInboxes : SEED_INBOXES_FALLBACK, results?.seedResults ?? null);

        showStep(3);
        document.getElementById("btn-recalculate").disabled = false;
        document.getElementById("recalc-icon").classList.remove("animate-spin");
      });
    }

    // "I've sent" → run check
    document.getElementById("btn-sent").addEventListener("click", () => runCheck());

    // Recalculate button
    document.getElementById("btn-recalculate").addEventListener("click", () => {
      if (!testId) return;
      document.getElementById("btn-recalculate").disabled = true;
      document.getElementById("recalc-icon").classList.add("animate-spin");
      runCheck();
    });

    // New test button
    document.getElementById("btn-restart").addEventListener("click", () => {
      resetState();
      initializeTest();
    });

    // Send report button
    document.getElementById("btn-send-report").addEventListener("click", async () => {
      const emailInput = document.getElementById("report-email");
      const errorEl = document.getElementById("report-error");
      const btn = document.getElementById("btn-send-report");
      const email = emailInput.value.trim();

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errorEl.textContent = "Please enter a valid email address.";
        errorEl.classList.remove("hidden");
        return;
      }
      errorEl.classList.add("hidden");

      if (!testId) {
        errorEl.textContent = "No test ID found. Please run a new test first.";
        errorEl.classList.remove("hidden");
        return;
      }

      btn.disabled = true;
      btn.textContent = "Sending…";

      try {
        const data = await apiPost(withToken(`/open/deliverability/tests/${testId}/send-report`), { email });
        if (data.success) {
          document.getElementById("report-form").classList.add("hidden");
          document.getElementById("report-success").classList.remove("hidden");
          // Full data is only accessible via the emailed link — do not unlock here
        } else {
          errorEl.textContent = data.message || "Failed to send. Please try again.";
          errorEl.classList.remove("hidden");
          btn.disabled = false;
          btn.textContent = "Send me the full report";
        }
      } catch {
        errorEl.textContent = "Something went wrong. Please try again.";
        errorEl.classList.remove("hidden");
        btn.disabled = false;
        btn.textContent = "Send me the full report";
      }
    });

    // Load full results from URL ?testId=&token= (emailed link)
    const urlParams = new URLSearchParams(window.location.search);
    const urlTestId = urlParams.get("testId");
    if (urlTestId) {
      testId      = urlTestId;
      viewToken   = urlParams.get("token") || "";
      reportToken = urlParams.get("reportToken") || "";
      showStep(2);
      document.querySelectorAll(".analysis-step").forEach(s => {
        s.classList.remove("active", "done");
        s.querySelector(".step-dot").innerHTML = "";
      });
      runAnalysisAnimation(async () => {
        try {
          // Use full-report endpoint when reportToken is present (emailed link)
          const endpoint = reportToken
            ? withReportToken(`/open/deliverability/tests/${testId}/full-report`)
            : withToken(`/open/deliverability/tests/${testId}/results`);
          const data = await apiGet(endpoint);
          const contentAnalysis = data.contentAnalysis || {};
          const { issues = [], positives = [], recommendations = [] } = contentAnalysis;
          const overallScore = data.overallScore ?? 0;

          const _pcts2 = derivePlacementPcts(data.placement, data.seedResults);
          let inboxPct = _pcts2?.inboxPct ?? 0;
          let spamPct  = _pcts2?.spamPct  ?? 0;
          let promoPct = _pcts2?.promoPct ?? 0;

          testState = { subject: "", body: "" };
          testCode = data.trackingCode || "";
          const sentDomain = data.senderReputation?.domain || data.contactEmail?.split("@")[1] || "";
          document.getElementById("results-sender").textContent =
            sentDomain ? `Domain: ${sentDomain} · Test ${testCode}` : testCode ? `Test ${testCode}` : "";
          const resultsCodeEl = document.getElementById("results-tracking-code");
          if (resultsCodeEl) resultsCodeEl.textContent = testCode;

          const repRecs = extractReputationRecs(data.senderReputation ?? null);
          const delivRecs = [];
          if (spamPct > 30) delivRecs.push(`${spamPct}% of your emails landed in spam. Fix SPF/DKIM/DMARC immediately and remove spam trigger words.`);
          else if (spamPct > 15) delivRecs.push(`${spamPct}% of emails hit spam. Review your sender reputation checks and email content.`);
          if (inboxPct < 50) delivRecs.push("Less than half your emails reach the primary inbox. Review all authentication checks.");
          if ((100 - inboxPct - spamPct) > 40) delivRecs.push("Over 40% of emails land in Promotions. Use plain text, fewer links, and a more personal tone.");

          renderScoreRing(Math.max(0, Math.min(100, overallScore)));
          renderPlacementDonut(inboxPct, Math.max(0, promoPct), spamPct);
          renderContentChecks(issues, positives);
          renderReputationChecks(data.contactEmail || "", data.senderReputation ?? null);
          renderRecommendations(recommendations, repRecs, delivRecs);
          renderSeedTable((data.seedInboxes?.length ? data.seedInboxes : SEED_INBOXES_FALLBACK), data.seedResults ?? null);
          showStep(3);
          // Full report from emailed link — unlock gate
          if (reportToken) unlockGate(spamPct);
        } catch {
          // reportToken invalid or expired — fall back to limited results view
          reportToken = "";
          try {
            const limited = await apiGet(withToken(`/open/deliverability/tests/${testId}/results`));
            const { issues = [], positives = [], recommendations = [] } = limited.contentAnalysis || {};
            const overallScore = limited.overallScore ?? 0;
            const _pcts3 = derivePlacementPcts(limited.placement, limited.seedResults);
            let inboxPct = _pcts3?.inboxPct ?? 0;
            let spamPct  = _pcts3?.spamPct  ?? 0;
            let promoPct = _pcts3?.promoPct ?? 0;
            testCode = limited.trackingCode || "";
            const limCodeEl = document.getElementById("results-tracking-code");
            if (limCodeEl) limCodeEl.textContent = testCode;
            renderScoreRing(Math.max(0, Math.min(100, overallScore)));
            renderPlacementDonut(inboxPct, Math.max(0, promoPct), spamPct);
            renderContentChecks(issues, positives);
            renderReputationChecks("", limited.senderReputation ?? null);
            renderRecommendations(recommendations, extractReputationRecs(limited.senderReputation ?? null), []);
            renderSeedTable((limited.seedInboxes?.length ? limited.seedInboxes : SEED_INBOXES_FALLBACK), limited.seedResults ?? null);
            showStep(3);
          } catch {
            initializeTest();
          }
        }
      });
    }

    // Copy tracking code on results page
    document.getElementById("copy-results-code-btn")?.addEventListener("click", function() {
      copyText(testCode, this);
    });

    // Generate AI content button (always visible in content analysis)
    document.getElementById("btn-generate-ai-content")?.addEventListener("click", () => {
      const section = document.getElementById("ai-fix-section");
      section?.classList.remove("hidden");
      if (!aiFixStarted && testId) fetchAiFix();
      section?.scrollIntoView({ behavior: "smooth", block: "nearest" });
    });

    // AI fix copy buttons
    document.getElementById("copy-ai-subject").addEventListener("click", function() {
      copyText(aiFixSubject, this);
    });
    document.getElementById("copy-ai-body").addEventListener("click", function() {
      copyText(aiFixBody, this);
    });

    // "Test this version" — create a new test with AI-generated content
    document.getElementById("btn-test-ai-version").addEventListener("click", () => {
      if (!aiFixSubject && !aiFixBody) return;
      const subj = aiFixSubject;
      const bod  = aiFixBody;
      resetState();
      initializeTest(subj, bod);
    });
  });
</script>
