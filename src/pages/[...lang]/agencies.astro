---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";

export function getStaticPaths() {
  return generatePaths();
}
---

<Base
  metaTitle="For Agencies | Scale Client Outbound | SendEmAll"
  disableTagline={true}
  metaDescription="Manage multiple clients, white-label reporting, volume pricing. SendEmAll is built for agencies that scale outbound."
>
  <!-- Hero -->
  <section class="py-24 lg:py-32">
    <div class="container text-center">
      <span class="mb-4 inline-block rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary" data-aos="fade-up-sm">For Agencies</span>
      <h1 class="mx-auto max-w-4xl text-4xl font-bold leading-tight sm:text-5xl lg:text-6xl" data-aos="fade-up-sm" data-aos-delay="100">
        Built for agencies that scale outbound
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-text-default/70" data-aos="fade-up-sm" data-aos-delay="200">
        Manage multiple clients, white-label reporting, volume pricing. One platform for every client campaign.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4" data-aos="fade-up-sm" data-aos-delay="300">
        <a href="/contact" class="btn btn-md btn-primary">Talk to our agency team</a>
        <a href="/pricing" class="btn btn-md btn-outline-white">See pricing</a>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-20 lg:py-28">
    <div class="container">
      <div class="mx-auto mb-16 max-w-2xl text-center">
        <h2 class="text-3xl font-bold sm:text-4xl" data-aos="fade-up-sm">Everything your agency needs</h2>
        <p class="mt-4 text-text-default/70" data-aos="fade-up-sm" data-aos-delay="100">Purpose-built features for multi-client outbound operations.</p>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { svg: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 19a2 2 0 0 0 2-2v-1a4 4 0 0 0-4-4h-1"/><path d="M6 19a2 2 0 0 1-2-2v-1a4 4 0 0 1 4-4h1"/><circle cx="15" cy="7" r="3"/><circle cx="9" cy="7" r="3"/></svg>', title: "Multi-client management", desc: "Separate workspaces per client with isolated data, campaigns, and reporting. No cross-contamination." },
          { svg: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>', title: "White-label capabilities", desc: "Reports and dashboards branded with your agency logo. Your clients see your brand, not ours." },
          { svg: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>', title: "Volume pricing", desc: "Agency-tier pricing that scales with your client count. The more clients, the better your margins." },
          { svg: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>', title: "Dedicated domains per client", desc: "Each client gets their own sending domains and infrastructure. Complete separation and deliverability." },
          { svg: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M8 13h8M8 17h5"/></svg>', title: "Centralized billing", desc: "One invoice for all clients. Allocate credits across accounts and track usage per client." },
          { svg: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>', title: "Priority support", desc: "Dedicated account manager, faster response times, and onboarding assistance for new client setups." },
        ].map((f, i) => (
          <div class="rounded-2xl border border-border-light bg-accent p-8" data-aos="fade-up-sm" data-aos-delay={i * 50}>
            <span class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary" set:html={f.svg} />
            <h3 class="mb-2 text-xl font-semibold">{f.title}</h3>
            <p class="text-text-default/70">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 lg:py-28">
    <div class="container">
      <div class="mx-auto mb-16 max-w-2xl text-center">
        <h2 class="text-3xl font-bold sm:text-4xl" data-aos="fade-up-sm">How it works</h2>
      </div>
      <div class="mx-auto grid max-w-4xl gap-12 lg:grid-cols-3">
        {[
          { num: "01", title: "Onboard your clients", desc: "Set up isolated workspaces with dedicated domains and sending infrastructure per client." },
          { num: "02", title: "We build separate pipelines", desc: "Each client gets their own discovery, qualification, and outreach pipeline tailored to their ICP." },
          { num: "03", title: "Launch and report", desc: "Run campaigns and share white-labeled performance reports with your clients." },
        ].map((s, i) => (
          <div class="text-center" data-aos="fade-up-sm" data-aos-delay={i * 100}>
            <span class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-full bg-primary text-lg font-bold text-dark">{s.num}</span>
            <h3 class="mb-2 text-xl font-semibold">{s.title}</h3>
            <p class="text-text-default/70">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 lg:py-28">
    <div class="container">
      <div class="mx-auto max-w-3xl rounded-2xl border border-border-light bg-accent p-12 text-center" data-aos="fade-up-sm">
        <h2 class="text-3xl font-bold sm:text-4xl">Ready to scale your agency?</h2>
        <p class="mx-auto mt-4 max-w-xl text-text-default/70">Get volume pricing, white-label reporting, and dedicated support for your agency.</p>
        <a href="/contact" class="btn btn-md btn-primary mt-8">Talk to our agency team</a>
      </div>
    </div>
  </section>
</Base>
