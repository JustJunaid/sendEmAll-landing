---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import ComparePage from "@/layouts/components/sections/ComparePage.astro";

export function getStaticPaths() {
  return generatePaths();
}

const features = [
  { name: "Data enrichment", competitor: "150+ providers", sendemall: "18+ focused on signals" },
  { name: "Workflow builder", competitor: "Spreadsheet-based", sendemall: "Automated pipeline" },
  { name: "Email sending", competitor: "No", sendemall: "Full campaign platform" },
  { name: "warmup", competitor: "No", sendemall: "Included" },
  { name: "Infrastructure", competitor: "No", sendemall: "Fully managed" },
  { name: "Pricing model", competitor: "Credits from $185/mo", sendemall: "All-inclusive from $149/mo" },
  { name: "Reply guarantee", competitor: "No", sendemall: "Business+Scale" },
];

const theyDoBetter = [
  { title: "Flexible data orchestration", description: "Clay's spreadsheet-based workflow builder is powerful for custom enrichment flows. If you need maximum flexibility in how you combine data sources, Clay is hard to beat." },
  { title: "150+ data providers", description: "More raw data provider integrations than any other tool. Great for teams that need very specific enrichment combinations." },
  { title: "Developer-friendly workflows", description: "Technical teams love building custom Clay tables with formulas, API calls, and conditional logic." },
];

const weDoBetter = [
  { title: "Full execution, not just data", description: "Clay stops at enrichment. We discover, enrich, verify, personalize, and send. One platform replaces your entire outbound stack." },
  { title: "Managed infrastructure", description: "Clay does not send emails. You still need a sending tool, domains, mailboxes, and warmup. We include all of it." },
  { title: "Simpler pricing", description: "Clay charges per-row credits that deplete unpredictably. Our pricing is straightforward: $149/mo for 1,500 credits, everything included. No per-row math." },
  { title: "Signal-based qualification built in", description: "Clay enriches contacts you already have. We find the right contacts in the first place by monitoring buying signals across 18+ sources." },
];
---

<Base
  title="Best Clay Alternative for Cold Email (2026) | SendEmAll"
  disableTagline={true}
  description="Clay orchestrates data. SendEmAll orchestrates your entire outbound pipeline. From signal detection to inbox delivery."
>
  <ComparePage
    competitor="Clay"
    description="Clay orchestrates data. SendEmAll orchestrates your entire outbound pipeline. From signal detection to inbox delivery."
    competitorPrice="$185-$800/mo"
    competitorPriceNote="Enrichment and workflow automation only. No sending, no infrastructure, no lead discovery."
    sendemallPrice="$149/mo"
    features={features}
    theyDoBetter={theyDoBetter}
    weDoBetter={weDoBetter}
    integrationNote="Clay is great for complex enrichment workflows. If you want the full pipeline without building it yourself, SendEmAll handles everything from signal detection to inbox delivery."
  />
</Base>
