---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import ComparePage from "@/layouts/components/sections/ComparePage.astro";

export function getStaticPaths() {
  return generatePaths();
}

const features = [
  { name: "Enrichment", competitor: "Powerful workflows", sendemall: "Automated" },
  { name: "Sending", competitor: "None", sendemall: "Full" },
  { name: "Infrastructure", competitor: "None", sendemall: "Managed" },
  { name: "Lead generation", competitor: "With integrations", sendemall: "Built-in" },
  { name: "Ease of use", competitor: "Technical", sendemall: "Guided self-serve" },
  { name: "API", competitor: "Yes", sendemall: "Yes" },
];

const theyDoBetter = [
  { title: "Flexibility", description: "Clay's workflow builder is incredibly powerful for custom enrichment flows." },
  { title: "Enrichment depth", description: "80+ data providers. If you need custom waterfall enrichment, Clay excels." },
];

const weDoBetter = [
  { title: "End-to-end platform", description: "Clay enriches. We discover, enrich, verify, personalize, AND send." },
  { title: "No technical setup", description: "Clay requires building workflows. We're guided self-serve — describe your buyer, we handle the rest." },
  { title: "Managed infrastructure", description: "Clay doesn't send emails. You'd need another tool for that." },
];
---

<Base
  title="SendEmAll vs Clay | Comparison"
  meta_title="SendEmAll vs Clay | Full Cost & Feature Comparison"
  description="Compare SendEmAll and Clay side by side. See how an end-to-end platform compares to a powerful enrichment tool."
>
  <ComparePage
    competitor="Clay"
    description="Side-by-side cost and feature comparison"
    competitorPrice="$149–$800/mo"
    competitorPriceNote="Enrichment and workflow automation only. No sending, no infrastructure."
    sendemallPrice="$149/mo"
    features={features}
    theyDoBetter={theyDoBetter}
    weDoBetter={weDoBetter}
    integrationNote="Clay is great for enrichment workflows. Use SendEmAll if you want the full pipeline without building it yourself."
  />
</Base>
