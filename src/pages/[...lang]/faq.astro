---
import Base from "@/layouts/Base.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import FaqSection from "@/components/sections/FaqSection.astro";
import CallToAction from "@/components/sections/CallToAction.astro";

export function getStaticPaths() {
  return generatePaths();
}

const faqData = (await getEntryCTM("faq", "-index", Astro.currentLocale))?.data;

// FAQPage schema for rich snippets
const faqItems = faqData?.list?.flatMap((category: any) =>
  category.list?.map((item: any) => ({
    "@type": "Question",
    name: item.title,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.content?.trim(),
    },
  })) ?? []
) ?? [];

const faqSchema = faqItems.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems,
}) : null;
---

<Base
  metaTitle="FAQ | SendEmAll — Signal-Based Outbound Platform"
  metaDescription={faqData?.metaDescription || "Answers to common questions about SendEmAll, signal-based outbound, pricing, deliverability, and more."}
  disableTagline={true}
>
  {faqSchema && <script type="application/ld+json" set:html={faqSchema} />}

  <FaqSection content={{
    ...faqData,
    showCategories: true,
  }} />

  <CallToAction />
</Base>
