---
interface Feature {
  name: string;
  competitor: string;
  sendemall: string;
}

interface Assessment {
  title: string;
  description: string;
}

interface Props {
  competitor: string;
  description: string;
  competitorPrice: string;
  competitorPriceNote: string;
  sendemallPrice: string;
  features: Feature[];
  theyDoBetter: Assessment[];
  weDoBetter: Assessment[];
  integrationNote: string;
}

const {
  competitor,
  description,
  competitorPrice,
  competitorPriceNote,
  sendemallPrice,
  features,
  theyDoBetter,
  weDoBetter,
  integrationNote,
} = Astro.props;

function isPositive(value: string): boolean {
  const lower = value.toLowerCase();
  return lower === "yes" || lower === "included" || lower === "full" || lower === "full ai research" || lower === "managed" || lower === "fully managed" || lower === "automated" || lower === "built-in" || lower === "guided self-serve" || lower === "multi-layer" || lower === "5+ providers" || lower === "signal-qualified" || lower === "business+scale";
}

function isNegative(value: string): boolean {
  const lower = value.toLowerCase();
  return lower === "no" || lower === "none" || lower === "byo";
}
---

<!-- Hero -->
<section class="pb-16 pt-32 md:pb-24 md:pt-40">
  <div class="container">
    <div class="mx-auto max-w-3xl text-center" data-aos="fade-up-sm">
      <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-primary">
        Comparison
      </span>
      <h1 class="font-secondary text-4xl font-bold text-white md:text-6xl/tight">
        SendEmAll vs {competitor}
      </h1>
      <p class="mt-6 text-lg text-text-default md:text-xl">
        {description}
      </p>
    </div>
  </div>
</section>

<!-- Cost Breakdown -->
<section class="py-16 md:py-24">
  <div class="container">
    <div class="mx-auto mb-12 max-w-2xl text-center" data-aos="fade-up-sm">
      <h2 class="font-secondary text-3xl font-bold text-white md:text-4xl">
        Cost Breakdown
      </h2>
    </div>

    <div class="mx-auto grid max-w-5xl gap-8 md:grid-cols-2">
      <!-- Competitor Card -->
      <div
        class="rounded-2xl border border-border-light bg-theme-dark p-8"
        data-aos="fade-up-sm"
        data-aos-delay="0"
      >
        <h3 class="mb-2 text-xl font-semibold text-white">
          <span class="mr-2 text-[#EF4444]">✕</span> {competitor}
        </h3>
        <div class="mb-4 text-3xl font-bold text-[#EF4444]">{competitorPrice}</div>
        <p class="text-sm text-text-default">{competitorPriceNote}</p>
      </div>

      <!-- SendEmAll Card -->
      <div
        class="relative rounded-2xl border border-primary/30 bg-theme-dark p-8"
        data-aos="fade-up-sm"
        data-aos-delay="100"
      >
        <span class="absolute -top-3 right-6 rounded-full bg-primary px-4 py-1 text-xs font-semibold text-dark">
          Better value
        </span>
        <h3 class="mb-2 text-xl font-semibold text-white">
          <span class="mr-2 text-primary">✓</span> SendEmAll
        </h3>
        <div class="mb-4 text-3xl font-bold text-primary">{sendemallPrice}</div>
        <p class="text-sm text-text-default">
          Everything included. Lead generation, enrichment, verification, AI personalization, managed infrastructure, and sending.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Feature Comparison Table -->
<section class="py-16 md:py-24">
  <div class="container">
    <div class="mx-auto mb-12 max-w-2xl text-center" data-aos="fade-up-sm">
      <h2 class="font-secondary text-3xl font-bold text-white md:text-4xl">
        Feature Comparison
      </h2>
    </div>

    <div class="mx-auto max-w-4xl overflow-hidden rounded-2xl border border-border-light" data-aos="fade-up-sm">
      <!-- Header -->
      <div class="grid grid-cols-3 bg-accent px-6 py-4">
        <span class="text-sm font-semibold uppercase tracking-wider text-text-default">Feature</span>
        <span class="text-center text-sm font-semibold uppercase tracking-wider text-text-default">{competitor}</span>
        <span class="text-center text-sm font-semibold uppercase tracking-wider text-primary">SendEmAll</span>
      </div>

      <!-- Rows -->
      {features.map((feature, i) => (
        <div class={`grid grid-cols-3 px-6 py-4 ${i % 2 === 0 ? "bg-theme-dark" : "bg-theme-dark/50"}`}>
          <span class="text-sm font-medium text-white">{feature.name}</span>
          <span class={`text-center text-sm ${isNegative(feature.competitor) ? "text-[#EF4444]" : isPositive(feature.competitor) ? "text-[#14B8A6]" : "text-text-default"}`}>
            {isNegative(feature.competitor) ? "✕ " : isPositive(feature.competitor) ? "✓ " : ""}{feature.competitor}
          </span>
          <span class={`text-center text-sm ${isNegative(feature.sendemall) ? "text-[#EF4444]" : isPositive(feature.sendemall) ? "text-[#14B8A6]" : "text-primary"}`}>
            {isNegative(feature.sendemall) ? "✕ " : isPositive(feature.sendemall) ? "✓ " : ""}{feature.sendemall}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Honest Assessment -->
<section class="py-16 md:py-24">
  <div class="container">
    <div class="mx-auto mb-12 max-w-2xl text-center" data-aos="fade-up-sm">
      <h2 class="font-secondary text-3xl font-bold text-white md:text-4xl">
        Honest Assessment
      </h2>
      <p class="mt-4 text-text-default">We believe in transparency. Even about our competitors.</p>
    </div>

    <div class="mx-auto grid max-w-5xl gap-8 md:grid-cols-2">
      <!-- Where Competitor Wins -->
      <div
        class="rounded-2xl border border-border-light bg-theme-dark p-8"
        data-aos="fade-up-sm"
        data-aos-delay="0"
      >
        <h3 class="mb-6 text-lg font-semibold text-white">
          Where {competitor} wins
        </h3>
        <div class="space-y-6">
          {theyDoBetter.map((item) => (
            <div>
              <h4 class="mb-1 font-semibold text-white">{item.title}</h4>
              <p class="text-sm text-text-default">{item.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Where SendEmAll Wins -->
      <div
        class="rounded-2xl border border-primary/30 bg-theme-dark p-8"
        data-aos="fade-up-sm"
        data-aos-delay="100"
      >
        <h3 class="mb-6 text-lg font-semibold text-primary">
          Where SendEmAll wins
        </h3>
        <div class="space-y-6">
          {weDoBetter.map((item) => (
            <div>
              <h4 class="mb-1 font-semibold text-white">{item.title}</h4>
              <p class="text-sm text-text-default">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Integration Fallback -->
<section class="py-16 md:py-24">
  <div class="container">
    <div
      class="mx-auto max-w-3xl rounded-2xl border border-border-light bg-theme-dark p-10 text-center"
      data-aos="fade-up-sm"
    >
      <h2 class="font-secondary text-2xl font-bold text-white md:text-3xl">
        Still want to use {competitor}?
      </h2>
      <p class="mt-4 text-text-default">{integrationNote}</p>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-16 md:py-24">
  <div class="container">
    <div class="mx-auto max-w-2xl text-center" data-aos="fade-up-sm">
      <h2 class="font-secondary text-3xl font-bold text-white md:text-4xl">
        Ready to simplify your outbound?
      </h2>
      <p class="mt-4 text-lg text-text-default">
        Start with 100 free credits. No credit card required.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href="/services/free-leads" class="btn btn-md btn-primary">
          Get 100 Qualified Potential Buyers
        </a>
        <a href="/pricing" class="btn btn-md btn-outline-primary">
          View Pricing
        </a>
      </div>
    </div>
  </div>
</section>
