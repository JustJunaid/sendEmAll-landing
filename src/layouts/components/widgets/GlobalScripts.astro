<script>
  // @ts-nocheck

  document.addEventListener("DOMContentLoaded", async () => {
    await initLucide();

    // Dynamic Preline imports
    await loadPrelineComponents();

    // AOS - https://github.com/michalsnik/aos
    const AOS = await import("aos");
    AOS.init({
      duration: 700,
      easing: "ease-out",
      disable: "mobile",
      once: true,
    });

    // Fix: Support horizontal scrolling by using the mouse wheel + shift
    initHorizontalScroll();
  });

  // Lucide Icons — tree-shaken import of only the icons actually used
  async function initLucide() {
    if (!document.querySelector("[data-lucide]")) return;

    const {
      createIcons,
      ChevronDown,
      ChevronUp,
      ChevronLeft,
      Star,
      ArrowUpRight,
      X,
    } = await import("lucide");

    createIcons({
      icons: { ChevronDown, ChevronUp, ChevronLeft, Star, ArrowUpRight, X },
    });
  }

  // Load Preline components dynamically based on DOM content
  async function loadPrelineComponents() {
    const hasComponent = (selectors: string[]) =>
      selectors.some((selector) => document.querySelector(selector));

    // Preline modules use default exports — resolve named or default
    const resolve = (mod: any, name: string) => mod[name] || mod.default;

    if (hasComponent([".hs-overlay", "[data-hs-overlay]"])) {
      resolve(await import("preline/dist/overlay.mjs"), "HSOverlay")?.autoInit();
    }
    if (hasComponent([".hs-dropdown", "[data-hs-dropdown]"])) {
      resolve(await import("preline/dist/dropdown.mjs"), "HSDropdown")?.autoInit();
    }
    if (hasComponent([".hs-select", "[data-hs-select]"])) {
      resolve(await import("preline/dist/select.mjs"), "HSSelect")?.autoInit();
    }
    if (hasComponent(["[data-hs-tab]", ".hs-tab", '[role="tablist"] [data-hs-tab]'])) {
      resolve(await import("preline/dist/tabs.mjs"), "HSTabs")?.autoInit();
    }
    if (hasComponent([".hs-accordion"])) {
      resolve(await import("preline/dist/accordion.mjs"), "HSAccordion")?.autoInit();
    }
    if (hasComponent([".hs-collapse", "[data-hs-collapse]"])) {
      resolve(await import("preline/dist/collapse.mjs"), "HSCollapse")?.autoInit();
    }
  }

  // Horizontal scroll with shift + wheel (targets only marked containers)
  function initHorizontalScroll() {
    document.querySelectorAll(".has-horizontal-scroll").forEach((el) => {
      el.addEventListener("wheel", function(event) {
        if (event.shiftKey) {
          event.preventDefault();
          this.scrollBy({ left: event.deltaY * 3, behavior: "smooth" });
        }
      }, { passive: false });
    });
  }

  // --- Page Intent & CTA Tracking ---
  // Fires GA4 events for high-intent page visits and CTA clicks.
  // Uses dynamic import so tracking module only loads when needed.
  (function initTracking() {
    const path = window.location.pathname;

    // High-intent page views
    const intentPages: Record<string, string> = {
      "/pricing": "pricing",
      "/compare/": "compare",
      "/products/": "product",
      "/services/free-leads": "free_leads",
      "/services/": "service",
    };

    for (const [prefix, name] of Object.entries(intentPages)) {
      if (path === prefix || path.startsWith(prefix)) {
        import("@/lib/utils/tracking").then(({ trackPageIntent }) => {
          trackPageIntent(name);
        });
        break;
      }
    }

    // CTA click tracking — all primary CTA buttons
    document.addEventListener("click", (e) => {
      const link = (e.target as HTMLElement).closest("a.btn-primary, a.btn");
      if (!link) return;
      const label = link.textContent?.trim() || "";
      const href = link.getAttribute("href") || "";
      if (label && href) {
        import("@/lib/utils/tracking").then(({ trackCTAClick }) => {
          trackCTAClick(label, href);
        });
      }
    });

    // UTM persistence — capture UTMs on ANY page, not just form pages.
    // This ensures UTMs from blog posts, compare pages, etc. survive
    // navigation to the form page.
    const params = new URLSearchParams(window.location.search);
    const utmKeys = ["utm_source", "utm_medium", "utm_campaign", "utm_content", "utm_term"];
    const hasUtm = utmKeys.some((k) => params.has(k));
    if (hasUtm) {
      let stored: Record<string, string> = {};
      try { stored = JSON.parse(sessionStorage.getItem("utm") ?? "{}"); } catch {}
      for (const key of utmKeys) {
        if (params.get(key)) stored[key] = params.get(key)!;
      }
      sessionStorage.setItem("utm", JSON.stringify(stored));
    }
  })();
</script>
